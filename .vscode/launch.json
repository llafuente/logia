    "version": "0.2.0",
    "configurations": [
      {
        "type": "cppvsdbg",
        "request": "launch",
        "name": "Debug logia with cppvsdbg",
        "program": "${workspaceFolder}/build-debug/bin/Debug/logia.exe",
        //"args": ["run", ".\\test\\logia\\sum.logia", "--print"],
        "args": ["run", ".\\test\\logia\\helloworld.logia"],
        "cwd": "${workspaceFolder}",
        "preLaunchTask": "CMake: build compiler",
      },
      {
        "type": "cppvsdbg",
        "request": "launch",
        "name": "Debug logia tests with cppvsdbg",
        "program": "${workspaceFolder}/build-debug/bin/Debug/logia_test_suite.exe",
        "args": [],
        "cwd": "${workspaceFolder}",
        "preLaunchTask": "CMake: build tests",
      },
      {
        // lldb is so slow... maybe made in python
        "type": "lldb",
        "request": "launch",
        "name": "Debug logia tests LLDB",
        "program": "${workspaceFolder}/build-debug/bin/Debug/logia_test_suite.exe",
        "args": [],
        "cwd": "${workspaceFolder}",
        "preLaunchTask": "CMake: build",
      },
    ]
}